---
interface Props {
  title?: string;
  description?: string;
  ogImage?: string | null;
}
const { title = 'Dane Wetton', description = 'Photography', ogImage = '/og-default.jpg' } = Astro.props;
const currentPath = Astro.url.pathname;

const fullTitle = title === 'Dane Wetton' ? 'Dane Wetton — Photography' : `${title} — Dane Wetton`;
// Absolute URLs are required for canonical + social tags. Astro.site comes from astro.config.
const canonical = new URL(currentPath, Astro.site).href;
const cleanOgImage = ogImage?.trim() || '/og-default.jpg';
const ogImageUrl = new URL(cleanOgImage, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph (Facebook, LinkedIn, iMessage previews) -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="Dane Wetton" />

    <!-- Twitter / X card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Archivo:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet" />
  </head>
  <body>
    <!-- Fixed left pane: logo on top, nav beneath. Stays put while the page scrolls.
         Replace the <span> with an <img src="/logo.svg" alt="Dane Wetton" /> when you have artwork. -->
    <aside class="sidebar">
      <a href="/" class="logo" aria-label="Dane Wetton — home">
        <img src="/DaneWetton1.png" alt="Dane Wetton" />
      </a>

      <nav class="side-nav">
        <a href="/" class:list={[{ active: currentPath === '/' }]}>Work</a>
        <a href="/journal" class:list={[{ active: currentPath.startsWith('/journal') }]}>Journal</a>
        <a href="/contact" class:list={[{ active: currentPath.startsWith('/contact') }]}>Contact</a>
      </nav>

      <a href="https://www.instagram.com/danewett" class="social-ig" target="_blank" rel="noopener noreferrer" aria-label="Dane Wetton on Instagram">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <circle cx="12" cy="12" r="4"/>
          <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
        </svg>
      </a>
    </aside>

    <main>
      <slot />
    </main>

    <footer>
      <span>© {new Date().getFullYear()} Dane Wetton</span>
      <span>All rights reserved</span>
    </footer>
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --white: #ffffff;
    --black: #0f0f0f;
    --mid: #8a8a8a;
    --border: #e8e8e4;
    --font-sans: 'Archivo', system-ui, -apple-system, sans-serif;
    /* Legacy aliases so existing page styles keep resolving to the new typeface. */
    --font-serif: var(--font-sans);
    --font-jp: var(--font-sans);
    --nav-w: clamp(160px, 16vw, 220px);
    --bar-h: 92px; /* height of the top bar on mobile */
  }

  html {
    background: var(--white);
    color: var(--black);
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
  }

  body {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    /* Reserve space for the fixed left pane. */
    padding-left: var(--nav-w);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    display: block;
    max-width: 100%;
  }

  /* ── Fixed left pane: logo + nav, stays put while the page scrolls ── */
  .sidebar {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 100;
    width: var(--nav-w);
    height: 100dvh;
    display: flex;
    flex-direction: column;
    padding: 2.5rem clamp(1.5rem, 3vw, 2.5rem);
    background: var(--white);
    border-right: 1px solid var(--border);
  }

  .logo {
    display: inline-flex;
    align-items: center;
    justify-content: flex-start;
  }

  .logo img {
    max-height: 56px;
    width: auto;
  }

  .logo-placeholder {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 120px;
    height: 48px;
    border: 1px solid var(--border);
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.72rem;
    letter-spacing: 0.3em;
    text-indent: 0.3em;
    color: var(--black);
  }

  /* ── Nav (vertical), sits below the logo inside the pane ── */
  .side-nav {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    margin-top: 2.75rem;
  }

  .side-nav a {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--mid);
    transition: color 0.2s ease;
    width: fit-content;
  }

  .side-nav a:hover,
  .side-nav a.active {
    color: var(--black);
  }

  /* ── Instagram link — in sidebar below nav ── */
  .social-ig {
    display: inline-flex;
    margin-top: 2rem;
    color: var(--mid);
    transition: color 0.2s ease;
    line-height: 0;
  }

  .social-ig:hover {
    color: var(--black);
  }

  /* ── Main ── */
  main {
    flex: 1;
  }

  /* ── Footer ── */
  footer {
    display: flex;
    justify-content: space-between;
    padding: 2rem clamp(1.5rem, 5vw, 4rem);
    border-top: 1px solid var(--border);
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.66rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--mid);
  }

  /* ── Page heading utility ── */
  .page-heading {
    padding: 5rem clamp(1.5rem, 5vw, 4rem) 3rem;
    border-bottom: 1px solid var(--border);
  }

  .page-heading h1 {
    font-family: var(--font-sans);
    font-weight: 800;
    font-size: clamp(2rem, 5.5vw, 3.6rem);
    letter-spacing: -0.02em;
    text-transform: uppercase;
  }

  .page-heading p {
    margin-top: 1rem;
    font-size: 1rem;
    color: var(--mid);
    max-width: 46ch;
    line-height: 1.7;
  }

  /* ── Mobile: the pane becomes a compact top bar (logo, then nav row) ── */
  @media (max-width: 768px) {
    body {
      padding-left: 0;
      padding-top: var(--bar-h);
    }

    .sidebar {
      width: auto;
      right: 0;
      height: var(--bar-h);
      flex-direction: column;
      align-items: flex-start;
      justify-content: center;
      gap: 0.6rem;
      padding: 0 clamp(1rem, 5vw, 1.5rem);
      border-right: none;
      border-bottom: 1px solid var(--border);
    }

    .logo-placeholder {
      width: 96px;
      height: 34px;
    }

    .side-nav {
      flex-direction: row;
      gap: clamp(1.1rem, 5vw, 2rem);
      margin-top: 0;
    }

    .side-nav a {
      font-size: 0.7rem;
    }
  }
</style>
