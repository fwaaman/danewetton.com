---
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}
const { title = 'Dane Wetton', description = 'Photography', ogImage = '/og-default.jpg' } = Astro.props;
const currentPath = Astro.url.pathname;

const fullTitle = title === 'Dane Wetton' ? 'Dane Wetton — Photography' : `${title} — Dane Wetton`;
// Absolute URLs are required for canonical + social tags. Astro.site comes from astro.config.
const canonical = new URL(currentPath, Astro.site).href;
const ogImageUrl = new URL(ogImage, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph (Facebook, LinkedIn, iMessage previews) -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="Dane Wetton" />

    <!-- Twitter / X card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Archivo:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet" />
  </head>
  <body>
    <!-- Logo placeholder, top centre. Replace the <a> contents with an <img src="/logo.svg" alt="Dane Wetton" /> when you have artwork. -->
    <header>
      <a href="/" class="logo" aria-label="Dane Wetton — home">
        <span class="logo-placeholder">LOGO</span>
      </a>
    </header>

    <nav class="side-nav">
      <a href="/" class:list={[{ active: currentPath === '/' }]}>Work</a>
      <a href="/services" class:list={[{ active: currentPath.startsWith('/services') }]}>Services</a>
      <a href="/journal" class:list={[{ active: currentPath.startsWith('/journal') }]}>Journal</a>
      <a href="/contact" class:list={[{ active: currentPath.startsWith('/contact') }]}>Contact</a>
    </nav>

    <main>
      <slot />
    </main>

    <footer>
      <span>© {new Date().getFullYear()} Dane Wetton</span>
      <span>All rights reserved</span>
    </footer>
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --white: #fafaf8;
    --black: #0f0f0f;
    --mid: #8a8a8a;
    --border: #e8e8e4;
    --font-sans: 'Archivo', system-ui, -apple-system, sans-serif;
    /* Legacy aliases so existing page styles keep resolving to the new typeface. */
    --font-serif: var(--font-sans);
    --font-jp: var(--font-sans);
    --logo-h: 96px;
    --nav-w: clamp(150px, 15vw, 210px);
  }

  html {
    background: var(--white);
    color: var(--black);
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
  }

  body {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    /* Reserve space for the fixed logo bar (top) and side nav (left). */
    padding-top: var(--logo-h);
    padding-left: var(--nav-w);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    display: block;
    max-width: 100%;
  }

  /* ── Logo bar (top centre) ── */
  header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: var(--logo-h);
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--white);
    border-bottom: 1px solid var(--border);
  }

  .logo {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .logo img {
    max-height: 56px;
    width: auto;
  }

  .logo-placeholder {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 120px;
    height: 48px;
    border: 1px solid var(--border);
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.72rem;
    letter-spacing: 0.3em;
    text-indent: 0.3em;
    color: var(--black);
  }

  /* ── Side nav (vertical, left) ── */
  .side-nav {
    position: fixed;
    top: var(--logo-h);
    left: 0;
    z-index: 90;
    width: var(--nav-w);
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    padding: 3rem clamp(1.5rem, 3vw, 2.5rem);
  }

  .side-nav a {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--mid);
    transition: color 0.2s ease;
    width: fit-content;
  }

  .side-nav a:hover,
  .side-nav a.active {
    color: var(--black);
  }

  /* ── Main ── */
  main {
    flex: 1;
  }

  /* ── Footer ── */
  footer {
    display: flex;
    justify-content: space-between;
    padding: 2rem clamp(1.5rem, 5vw, 4rem);
    border-top: 1px solid var(--border);
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.66rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--mid);
  }

  /* ── Page heading utility ── */
  .page-heading {
    padding: 5rem clamp(1.5rem, 5vw, 4rem) 3rem;
    border-bottom: 1px solid var(--border);
  }

  .page-heading h1 {
    font-family: var(--font-sans);
    font-weight: 800;
    font-size: clamp(2rem, 5.5vw, 3.6rem);
    letter-spacing: -0.02em;
    text-transform: uppercase;
  }

  .page-heading p {
    margin-top: 1rem;
    font-size: 1rem;
    color: var(--mid);
    max-width: 46ch;
    line-height: 1.7;
  }

  /* ── Mobile: logo on top, nav as a centred row beneath it ── */
  @media (max-width: 768px) {
    :root {
      --logo-h: 64px;
      --nav-row-h: 46px;
    }

    body {
      padding-top: calc(var(--logo-h) + var(--nav-row-h));
      padding-left: 0;
    }

    .logo-placeholder {
      width: 96px;
      height: 38px;
    }

    .side-nav {
      top: var(--logo-h);
      left: 0;
      right: 0;
      width: auto;
      height: var(--nav-row-h);
      flex-direction: row;
      justify-content: center;
      align-items: center;
      gap: clamp(1.25rem, 5vw, 2.5rem);
      padding: 0 1rem;
      background: var(--white);
      border-bottom: 1px solid var(--border);
    }

    .side-nav a {
      font-size: 0.7rem;
    }
  }
</style>
