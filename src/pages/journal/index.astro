---
import Layout from '../../layouts/Layout.astro';
import { getJournalPosts } from '../../lib/sanity';

// Published posts only, newest first, future-dated posts hidden — all handled in the query.
const posts = await getJournalPosts();

const fmtDate = (d: string) =>
  new Date(d).toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Layout title="Journal" description="Photography journal, camera reviews, and field notes by Dane Wetton.">
  <div class="page-heading">
    <h1>Journal</h1>
    <p>Camera reviews, field notes, and thoughts on making pictures.</p>
  </div>

  {posts.length === 0 ? (
    <div class="empty">
      <p>Coming soon.</p>
    </div>
  ) : (
    <ul class="post-list">
      {posts.map((post) => (
        <li>
          <a href={`/journal/${post.slug}/`} class="post-link">
            {post.coverSrc && (
              <div class="post-thumb">
                <img src={post.coverSrc} alt={post.coverAlt} loading="lazy" />
              </div>
            )}
            <div class="post-text">
              <time datetime={post.date}>{fmtDate(post.date)}</time>
              <h2>{post.title}</h2>
              <p>{post.excerpt}</p>
              {post.tags.length > 0 && (
                <div class="post-tags">
                  {post.tags.map((t) => <span class="tag">{t}</span>)}
                </div>
              )}
            </div>
          </a>
        </li>
      ))}
    </ul>
  )}
</Layout>

<style>
  .empty {
    padding: 4rem clamp(1.5rem, 5vw, 4rem);
    color: var(--mid);
    font-size: 1.05rem;
  }

  .post-list {
    list-style: none;
    border-top: 1px solid var(--border);
  }

  .post-link {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
    padding: 2.5rem clamp(1.5rem, 5vw, 4rem);
    border-bottom: 1px solid var(--border);
    transition: background 0.2s ease;
  }

  .post-link:hover {
    background: #f5f5f2;
  }

  .post-thumb {
    flex: 0 0 clamp(120px, 22vw, 240px);
    overflow: hidden;
    background: var(--border);
  }

  .post-thumb :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 4 / 3;
  }

  time {
    display: block;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.66rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--mid);
    margin-bottom: 0.6rem;
  }

  h2 {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(1.4rem, 2.8vw, 2rem);
    letter-spacing: -0.01em;
    margin-bottom: 0.6rem;
    line-height: 1.15;
  }

  .post-text p {
    font-size: 0.95rem;
    color: var(--mid);
    line-height: 1.7;
    max-width: 56ch;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .tag {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--mid);
    border: 1px solid var(--border);
    padding: 0.3rem 0.6rem;
  }

  @media (max-width: 600px) {
    .post-link {
      flex-direction: column;
      gap: 1.2rem;
    }
    .post-thumb {
      flex-basis: auto;
      width: 100%;
    }
  }
</style>
