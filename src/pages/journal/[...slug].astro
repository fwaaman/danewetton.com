---
import Layout from '../../layouts/Layout.astro';
import { getJournalSlugs, getJournalPost } from '../../lib/sanity';

export async function getStaticPaths() {
  const slugs = await getJournalSlugs();
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const post = await getJournalPost(slug!);

// A slug with no matching published post (e.g. just unpublished) → 404.
if (!post) {
  return Astro.redirect('/404');
}

const fmtDate = (d: string) =>
  new Date(d).toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' });

// Structured data so search engines understand this is an article (helps rich results).
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.title,
  description: post.excerpt,
  datePublished: new Date(post.date).toISOString(),
  author: { '@type': 'Person', name: 'Dane Wetton' },
  keywords: post.tags.join(', '),
  url: new URL(`/journal/${post.slug}/`, Astro.site).href,
};
---

<Layout title={post.title} description={post.excerpt} ogImage={post.coverSrc}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <article class="post">
    <header class="post-head">
      <a href="/journal/" class="back">&larr; Journal</a>
      <time datetime={post.date}>{fmtDate(post.date)}</time>
      <h1>{post.title}</h1>
      {post.tags.length > 0 && (
        <div class="post-tags">
          {post.tags.map((t) => <span class="tag">{t}</span>)}
        </div>
      )}
    </header>

    {post.coverSrc && (
      <div class="post-cover">
        <img src={post.coverSrc} alt={post.coverAlt} />
      </div>
    )}

    <div class="prose" set:html={post.bodyHtml} />
  </article>
</Layout>

<style>
  .post {
    max-width: 70ch;
    margin: 0 auto;
    padding: clamp(2.5rem, 6vw, 5rem) clamp(1.5rem, 5vw, 3rem) 6rem;
  }

  .back {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--mid);
    transition: color 0.2s ease;
  }

  .back:hover { color: var(--black); }

  .post-head time {
    display: block;
    margin-top: 2rem;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.68rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--mid);
  }

  .post-head h1 {
    margin-top: 0.8rem;
    font-family: var(--font-sans);
    font-weight: 800;
    font-size: clamp(1.9rem, 5vw, 3rem);
    letter-spacing: -0.02em;
    line-height: 1.08;
  }

  .post-head {
    margin-bottom: 2.5rem;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.5rem;
  }

  .tag {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--mid);
    border: 1px solid var(--border);
    padding: 0.3rem 0.6rem;
  }

  .post-cover {
    margin: 0 0 2.5rem;
    overflow: hidden;
    background: var(--border);
  }

  .post-cover :global(img) {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Long-form body typography ── */
  .prose {
    font-size: 1.08rem;
    line-height: 1.8;
    color: #1a1a1a;
  }

  .prose :global(h2) {
    font-weight: 700;
    font-size: clamp(1.4rem, 3vw, 1.8rem);
    letter-spacing: -0.01em;
    margin: 2.8rem 0 1rem;
    line-height: 1.2;
  }

  .prose :global(h3) {
    font-weight: 600;
    font-size: 1.25rem;
    margin: 2rem 0 0.8rem;
  }

  .prose :global(p) {
    margin: 0 0 1.4rem;
  }

  .prose :global(a) {
    color: var(--black);
    border-bottom: 1px solid var(--black);
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 1.4rem;
    padding-left: 1.4rem;
  }

  .prose :global(li) {
    margin-bottom: 0.5rem;
  }

  .prose :global(blockquote) {
    margin: 2rem 0;
    padding-left: 1.4rem;
    border-left: 2px solid var(--black);
    font-size: 1.2rem;
    line-height: 1.6;
    color: #333;
  }

  .prose :global(img) {
    width: 100%;
    height: auto;
    margin: 2rem 0;
  }

  .prose :global(code) {
    font-family: ui-monospace, monospace;
    font-size: 0.9em;
    background: #f0f0ec;
    padding: 0.15em 0.4em;
    border-radius: 3px;
  }
</style>
