---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Get in touch with Dane Wetton">
  <div class="page-heading">
    <h1>Contact</h1>
    <p>For commissions, licensing, or general enquiries.</p>
  </div>

  <div class="contact-wrap">
    <form
      class="contact-form"
      method="POST"
      action="https://formspree.io/f/YOUR_FORM_ID"
    >
      <div class="field">
        <label for="name">Name</label>
        <input type="text" id="name" name="name" required autocomplete="name" />
      </div>

      <div class="field">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required autocomplete="email" />
      </div>

      <div class="field">
        <label for="subject">Subject</label>
        <select id="subject" name="subject">
          <option value="">Select&hellip;</option>
          <option>Portrait commission</option>
          <option>Editorial commission</option>
          <option>Commercial commission</option>
          <option>Event coverage</option>
          <option>Licensing enquiry</option>
          <option>Other</option>
        </select>
      </div>

      <div class="field">
        <label for="message">Message</label>
        <textarea id="message" name="message" rows="6" required></textarea>
      </div>

      <button type="submit">Send message</button>
    </form>

    <aside class="contact-meta">
      <p class="meta-label">Response time</p>
      <p>Within 48 hours</p>
    </aside>
  </div>
</Layout>

<style>
  .contact-wrap {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    padding: 4rem clamp(1.5rem, 5vw, 4rem) 6rem;
    align-items: start;
  }

  @media (max-width: 768px) {
    .contact-wrap {
      grid-template-columns: 1fr;
    }
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  label {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.66rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--mid);
  }

  input,
  select,
  textarea {
    font-family: var(--font-serif);
    font-weight: 300;
    font-size: 1rem;
    color: var(--black);
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--border);
    padding: 0.6rem 0;
    outline: none;
    transition: border-color 0.2s ease;
    appearance: none;
    -webkit-appearance: none;
    border-radius: 0;
    width: 100%;
  }

  input:focus,
  select:focus,
  textarea:focus {
    border-bottom-color: var(--black);
  }

  textarea {
    resize: vertical;
  }

  button {
    align-self: flex-start;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--white);
    background: var(--black);
    border: none;
    padding: 1rem 2.5rem;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  button:hover {
    background: #333;
  }

  .contact-meta {
    padding-top: 0.4rem;
  }

  .meta-label {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.66rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--mid);
    margin-bottom: 0.5rem;
  }

  .contact-meta p:last-child {
    font-size: 1rem;
    color: var(--mid);
  }
</style>
