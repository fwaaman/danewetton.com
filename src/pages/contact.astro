---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Get in touch with Dane Wetton">
  <div class="page-heading">
    <h1>Contact</h1>
  </div>

  <div class="contact-wrap">
    <div class="form-col">
      <form class="contact-form" id="contact-form" method="POST" action="https://formspree.io/f/mojzyavd">
        <div class="field">
          <label for="name">Name</label>
          <input type="text" id="name" name="name" required autocomplete="name" />
        </div>

        <div class="field">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required autocomplete="email" />
        </div>

        <div class="field">
          <label for="subject">Subject</label>
          <select id="subject" name="subject">
            <option value="">Select&hellip;</option>
            <option>Portrait commission</option>
            <option>Editorial commission</option>
            <option>Commercial commission</option>
            <option>Event coverage</option>
            <option>Licensing enquiry</option>
            <option>Other</option>
          </select>
        </div>

        <div class="field">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="6" required></textarea>
        </div>

        <!-- Honeypot: hidden from people, catches spam bots that fill every field. -->
        <input type="text" name="_gotcha" class="hp" tabindex="-1" autocomplete="off" aria-hidden="true" />

        <button type="submit">Send message</button>
        <p class="form-status" role="alert" aria-live="polite"></p>
      </form>

      <div class="form-success" hidden>
        <p class="success-head">Thank you.</p>
        <p>Your message has been sent — I'll be in touch within 48 hours.</p>
      </div>
    </div>

  </div>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  if (form) {
    const status = form.querySelector('.form-status') as HTMLElement;
    const button = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const success = document.querySelector('.form-success') as HTMLElement | null;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      status.textContent = '';
      button.disabled = true;
      button.textContent = 'Sending…';

      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });

        if (res.ok) {
          form.hidden = true;
          if (success) success.hidden = false;
        } else {
          const data = await res.json().catch(() => null);
          status.textContent =
            data?.errors?.[0]?.message ||
            'Something went wrong. Please email hello@danewetton.com directly.';
          button.disabled = false;
          button.textContent = 'Send message';
        }
      } catch {
        status.textContent = 'Network error. Please email hello@danewetton.com directly.';
        button.disabled = false;
        button.textContent = 'Send message';
      }
    });
  }
</script>

<style>
  .contact-wrap {
    padding: 4rem clamp(1.5rem, 5vw, 4rem) 6rem;
    max-width: 600px;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  label {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.66rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--mid);
  }

  input,
  select,
  textarea {
    font-family: var(--font-serif);
    font-weight: 300;
    font-size: 1rem;
    color: var(--black);
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--border);
    padding: 0.6rem 0;
    outline: none;
    transition: border-color 0.2s ease;
    appearance: none;
    -webkit-appearance: none;
    border-radius: 0;
    width: 100%;
  }

  input:focus,
  select:focus,
  textarea:focus {
    border-bottom-color: var(--black);
  }

  textarea {
    resize: vertical;
  }

  button {
    align-self: flex-start;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--white);
    background: var(--black);
    border: none;
    padding: 1rem 2.5rem;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  button:hover {
    background: #333;
  }

  button:disabled {
    opacity: 0.5;
    cursor: default;
  }

  /* Honeypot — visually hidden, off-screen, not announced. */
  .hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }

  .form-status:empty {
    display: none;
  }

  .form-status {
    margin-top: -0.5rem;
    font-size: 0.9rem;
    color: #b00020;
  }

  .form-success .success-head {
    font-family: var(--font-sans);
    font-weight: 800;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    letter-spacing: -0.01em;
    margin-bottom: 0.75rem;
  }

  .form-success p:last-child {
    font-size: 1.05rem;
    color: var(--mid);
    line-height: 1.7;
    max-width: 40ch;
  }

</style>
