# Contentful — copy this file to `.env` and fill in the values.
# Find these in Contentful under Settings → API keys (create an API key if needed).

# Settings → General settings → Space ID
CONTENTFUL_SPACE_ID=

# Settings → API keys → your key → "Content Delivery API - access token"
CONTENTFUL_DELIVERY_TOKEN=

# Usually "master"; only change if you publish from a different environment.
CONTENTFUL_ENVIRONMENT=master
